# MySQL (required for Hostinger and local dev)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=nature_secret
MYSQL_PASSWORD=nature_secret_dev
MYSQL_DATABASE=nature_secret
# Optional: root password for scripts/setup-local-mysql.sh (local MySQL without Docker)
# MYSQL_ROOT_PASSWORD=

JWT_SECRET=change-this-to-a-long-random-secret-in-production
ENCRYPTION_KEY=change-this-to-32-chars-or-more-in-production
PORT=4000
FRONTEND_ORIGIN=http://localhost:3000
API_PUBLIC_URL=http://localhost:4000

# Persistent uploads: set to an absolute path outside the app so product/blog/slider images survive redeploys (e.g. /var/data/nature-secret)
# UPLOAD_ROOT=/var/data/nature-secret

# Gmail (order confirmation email) – use App Password if 2FA enabled
GMAIL_USER=your@gmail.com
GMAIL_APP_PASSWORD=

# Twilio (WhatsApp order confirmation + reply-to-confirm)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Webhook auth (WhatsApp incoming): set WEBHOOK_SECRET and send it in header X-Webhook-Secret or Authorization: Bearer <secret>
WEBHOOK_SECRET=

# First-time admin seed: set SETUP_SECRET and call POST /api/v1/setup/seed-admin with header X-Setup-Secret
SETUP_SECRET=
