{
  "name": "nature-secret-api",
  "version": "1.0.0",
  "scripts": {
    "build": "npx nest build && (cp -r public dist/ 2>/dev/null || true)",
    "start": "node dist/main.js",
    "start:prod": "node dist/main.js",
    "start:staging": "NODE_ENV=production node server.js",
    "typeorm": "npx ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js",
    "migration:run": "npm run typeorm -- migration:run -d src/database/data-source.js",
    "migration:generate": "npm run typeorm -- migration:generate -d src/database/data-source.js",
    "db:setup": "npx ts-node -r tsconfig-paths/register src/db-sync-and-seed.ts",
    "db:setup:prod": "node dist/db-sync-and-seed.js",
    "db:sync-seed": "npm run db:setup",
    "seed": "npm run db:setup",
    "seeds": "npm run db:setup",
    "seed:admin": "node seed-admin.js",
    "seed:admin-categories": "node seed-admin-and-categories.js",
    "cron:restart-if-down": "bash scripts/check-and-restart.sh"
  },
  "dependencies": {
    "@nestjs/cli": "^10.3.0",
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^3.1.1",
    "@nestjs/core": "^10.3.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/platform-socket.io": "^10.3.0",
    "@nestjs/throttler": "^5.1.1",
    "@nestjs/typeorm": "^10.0.2",
    "@nestjs/websockets": "^10.3.0",
    "@types/compression": "^1.7.5",
    "@types/express": "^4.17.21",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.10.6",
    "@types/nodemailer": "^6.4.14",
    "@types/passport-jwt": "^4.0.0",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "compression": "^1.7.4",
    "mysql2": "^3.6.5",
    "nodemailer": "^6.9.8",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1",
    "socket.io": "^4.7.4",
    "twilio": "^4.23.0",
    "typeorm": "^0.3.19",
    "typescript": "^5.3.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "readable-stream": "^4.5.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0"
  },
  "overrides": {
    "readable-stream": "^4.5.0"
  }
}
